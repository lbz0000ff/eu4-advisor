# ── LLM Provider 配置 ──
# 支持任何 OpenAI 兼容的 API，修改 LLM_BASE_URL 即可切换。

# 本地模型 (Ollama)
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=qwen2.5:14b

# DeepSeek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Embedding 与重排模型。默认填写 Hugging Face 模型 ID，首次运行时自动下载；
# 也可以改成本机已下载模型的目录。
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Hugging Face 下载较慢时可启用镜像。
# HF_ENDPOINT=https://hf-mirror.com

# 独立 LLM-as-Judge，支持任意 OpenAI 兼容接口。
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# 可选：兼容使用 UUAPI_BASE_URL、UUAPI_API_KEY 和 RACE_MODEL 的已有环境。
# UUAPI_BASE_URL=https://uuapi.net/v1
# UUAPI_API_KEY=
# RACE_MODEL=gpt-5.5

# SiliconFlow
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=
# LLM_MODEL=Qwen/Qwen3.5-4B

# OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# LM Studio 示例
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=请填写 LM Studio 中加载模型的 ID
